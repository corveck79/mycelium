.venv/
__pycache__/
*.pyc
.pytest_cache/
.env
# React/Vite build artefacts, rebuilt via Dockerfile or `npm run build`
frontend/node_modules/
frontend/dist/
frontend/src/plugins/
# static/app/ is tracked so `git pull` is enough to update the frontend
# without a separate build step on the NAS.
# Runtime data: DB, media, .strm files, backups. NEVER track these: a
# `git reset --hard` would otherwise wipe the live database.
data/
# Local-only dev/maintainer notes, not shipped to users
HANDOFF.md
CLAUDE.md
# Design system reference (not part of the app)
mycelium-design-system/
spore-nfs/spore-nfs
